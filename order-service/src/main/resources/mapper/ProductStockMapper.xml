<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.order.mapper.ProductStockMapper">

    <resultMap id="ProductMap" type="com.demo.common.entity.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="skuCode" column="sku_code"/>
        <result property="categoryId" column="category_id"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectById" resultMap="ProductMap">
        SELECT * FROM mall_product WHERE id = #{id}
    </select>

    <update id="deductStock">
        UPDATE mall_product
        SET stock = stock - #{qty}, update_time = NOW()
        WHERE id = #{id} AND stock >= #{qty}
    </update>

    <update id="addStock">
        UPDATE mall_product
        SET stock = stock + #{qty}, update_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
