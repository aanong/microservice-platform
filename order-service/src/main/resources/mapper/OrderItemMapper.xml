<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.order.mapper.OrderItemMapper">

    <resultMap id="OrderItemMap" type="com.demo.order.entity.OrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="skuCode" column="sku_code"/>
        <result property="salePrice" column="sale_price"/>
        <result property="quantity" column="quantity"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="realPayAmount" column="real_pay_amount"/>
        <result property="refundedQuantity" column="refunded_quantity"/>
        <result property="refundedAmount" column="refunded_amount"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByOrderId" resultMap="OrderItemMap">
        SELECT * FROM order_item WHERE order_id = #{orderId} ORDER BY id ASC
    </select>
</mapper>
