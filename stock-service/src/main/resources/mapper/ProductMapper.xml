<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.stock.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.demo.common.entity.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="skuCode" column="sku_code"/>
        <result property="categoryId" column="category_id"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectByCondition" resultMap="ProductResultMap">
        SELECT id, name, sku_code, category_id, price, stock, status, description, create_time, update_time
        FROM mall_product
        <where>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%') OR sku_code LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
